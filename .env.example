APP_NAME="Integration Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos (MySQL por defecto; cambiar DB_CONNECTION=pgsql para PostgreSQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=integration_hub
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

#------------------------------------------------------------
# Seguridad del integration-hub
#------------------------------------------------------------
INTEGRATION_API_KEY=cambia-esta-clave-en-produccion

#------------------------------------------------------------
# Zoho OAuth (región .com global)
#------------------------------------------------------------
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_BASE_URL=https://www.zohoapis.com/books/v3
ZOHO_HTTP_TIMEOUT=20

# Custom fields (api_name) en Zoho Books
ZOHO_CF_LINK_FACTURA_SIIGO=cf_linkdefacturasiigo
ZOHO_CF_TIPO_IDENTIFICACION=cf_tipo_de_identificaci_n
ZOHO_CF_NUMERO_IDENTIFICACION=cf_n_mero_de_identificaci_n

#------------------------------------------------------------
# Siigo Nube
#------------------------------------------------------------
SIIGO_API_BASE_URL=https://api.siigo.com
SIIGO_USERNAME=
SIIGO_ACCESS_KEY=
SIIGO_PARTNER_ID=integration-hub
SIIGO_HTTP_TIMEOUT=30

# Catálogos Siigo (IDs numéricos)
SIIGO_DOCUMENT_ID=
SIIGO_SELLER_ID=
SIIGO_PAYMENT_ID=
SIIGO_TAX_ID_IVA_19=

# Defaults para crear cliente Siigo desde un contacto Zoho (Colombia / Bogotá)
SIIGO_DEFAULT_COUNTRY_CODE=CO
SIIGO_DEFAULT_STATE_CODE=11
SIIGO_DEFAULT_CITY_CODE=11001
SIIGO_DEFAULT_ADDRESS=N/A
SIIGO_DEFAULT_ID_TYPE=13

# Facturación electrónica
SIIGO_INVOICE_SEND_DIAN=false
SIIGO_INVOICE_SEND_MAIL=false
